# --- Elasticsearch (choose ONE connection style) ---
# Classic Elastic Cloud: set cloud id + api key
ELASTIC_CLOUD_ID=
# OR Elastic Serverless / self-managed: set an https endpoint URL + api key
ELASTIC_URL=
ELASTIC_API_KEY=

# --- OpenRouter (Gemini) ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL=google/gemini-2.5-flash

# --- WAQI live air-quality feed ---
WAQI_TOKEN=

# NOTE: With none of these set, the app still runs fully offline in mock mode.
